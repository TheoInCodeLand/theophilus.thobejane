# Database Configuration
DATABASE_URL=

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Secret
SESSION_SECRET=your-secret-key-here

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password

# Cloudinary Configuration (for image/document uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pinecone Vector Database (for RAG chatbot)
PINECONE_API_KEY=
PINECONE_INDEX=web-portfolio
PINECONE_NAMESPACE=portfolio-knowledge

# Groq AI API (for LLM responses)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024

# OpenAI Embeddings (optional - for document indexing)
# If not provided, document indexing won't work
OPENAI_API_KEY=

# Alternative: HuggingFace Embeddings API
# HUGGINGFACE_API_KEY=