<div class="dashboard-container">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo">
        <div class="sidebar-logo-icon" style="border-radius: 50%; color: var(--primary); border: 1px solid var(--primary); background: var(--background);">TT</div>
        <div>
          <div class="sidebar-logo-text">Theophilus</div>
          <!-- <div class="sidebar-logo-sub">Dashboard</div> -->
        </div>
      </a>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-section-title">Overview</div>
        <button class="nav-item active" data-section="dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Dashboard
        </button>
      </div>

      <div class="nav-section">
        <div class="nav-section-title">Content</div>
        <button class="nav-item" data-section="blog">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          Blog Posts
          <span class="nav-item-badge" id="blogCount"><%= stats.blog.total %></span>
        </button>
        <button class="nav-item" data-section="projects">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Projects
          <span class="nav-item-badge" id="projectsCount"><%= stats.projects.total %></span>
        </button>
        <button class="nav-item" data-section="notes">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Lab Notes
          <span class="nav-item-badge" id="notesCount"><%= stats.notes.total %></span>
        </button>
        <button class="nav-item" data-section="workbench">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Workbench
          <span class="nav-item-badge" id="workbenchCount"><%= stats.workbench.total %></span>
        </button>
      </div>

      <div class="nav-section">
        <div class="nav-section-title">System</div>
        <button class="nav-item" data-section="settings">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
          Settings
        </button>
        <button class="nav-item" data-section="export">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          Import/Export
        </button>
      </div>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="btn btn-secondary" style="width: 100%; display: flex; justify-content: center; gap: 0.5rem; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border); font-size: 0.875rem;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        View Site
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <!-- Top Bar -->
    <header class="top-bar">
      <div class="top-bar-left">
        <button class="mobile-menu-btn-dash" id="mobileMenuBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="page-title" id="pageTitle">Dashboard</h1>
      </div>
      <div class="top-bar-right">
        <div class="search-container">
          <svg class="search-icon-dash" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" class="search-input-dash" placeholder="Search..." id="globalSearch">
        </div>
        <button class="btn btn-icon btn-ghost" id="darkModeToggle" title="Toggle dark mode">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20" id="darkModeIcon"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
      </div>
    </header>

    <!-- Dashboard Section -->
    <div class="section-content active" id="section-dashboard">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Welcome back!</h1>
            <p>Here's an overview of your content</p>
          </div>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-card-header">
              <div class="stat-card-icon primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
            </div>
            <div class="stat-card-value" id="statBlog"><%= stats.blog.total %></div>
            <div class="stat-card-label">Blog Posts</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-header">
              <div class="stat-card-icon success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z"/></svg>
              </div>
            </div>
            <div class="stat-card-value" id="statProjects"><%= stats.projects.total %></div>
            <div class="stat-card-label">Projects</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-header">
              <div class="stat-card-icon warning">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
            </div>
            <div class="stat-card-value" id="statNotes"><%= stats.notes.total %></div>
            <div class="stat-card-label">Lab Notes</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-header">
              <div class="stat-card-icon info">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg>
              </div>
            </div>
            <div class="stat-card-value" id="statWorkbench"><%= stats.workbench.total %></div>
            <div class="stat-card-label">Workbench Items</div>
          </div>
        </div>

        <div class="data-table-container">
          <div class="data-table-header">
            <h3>Quick Stats</h3>
          </div>
          <div style="padding: 1.5rem;" id="quickStats">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
              <div>
                <p style="font-size: 0.75rem; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Projects</p>
                <div style="display: flex; gap: 1rem;">
                  <div><span style="font-size: 1.5rem; font-weight: 700; color: #22c55e;"><%= stats.projects.shipped %></span> <span style="font-size: 0.75rem; color: var(--muted-foreground);">shipped</span></div>
                  <div><span style="font-size: 1.5rem; font-weight: 700; color: #3b82f6;"><%= stats.projects.in_progress %></span> <span style="font-size: 0.75rem; color: var(--muted-foreground);">in progress</span></div>
                </div>
              </div>
              <div>
                <p style="font-size: 0.75rem; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Blog Posts</p>
                <div style="display: flex; gap: 1rem;">
                  <div><span style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= stats.blog.published %></span> <span style="font-size: 0.75rem; color: var(--muted-foreground);">published</span></div>
                  <div><span style="font-size: 1.5rem; font-weight: 700; color: #f59e0b;"><%= stats.blog.featured %></span> <span style="font-size: 0.75rem; color: var(--muted-foreground);">featured</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Blog Posts Section -->
    <div class="section-content" id="section-blog">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Blog Posts</h1>
            <p>Manage your blog content</p>
          </div>
          <div class="page-actions">
            <button class="btn btn-primary" onclick="openBlogPostModal()" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Post
            </button>
            <a href="/blog" class="btn btn-secondary" style="padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 8px; font-size: 0.875rem;">View Blog</a>
          </div>
        </div>
        <div class="data-table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="blogTableBody">
              <% blogPosts.forEach(post => { %>
                <tr>
                  <td>
                    <div class="table-title"><%= post.title %></div>
                    <div class="table-subtitle"><%= post.excerpt.substring(0, 60) %>...</div>
                  </td>
                  <td><%= post.category_name || 'General' %></td>
                  <td>
                    <span class="badge <%= post.published ? 'badge-shipped' : 'badge-progress' %>">
                      <span class="badge-dot"></span>
                      <%= post.published ? 'Published' : 'Draft' %>
                    </span>
                  </td>
                  <td><%= new Date(post.published_at || post.created_at).toLocaleDateString() %></td>
                  <td>
                    <div class="table-actions">
                      <button class="btn btn-ghost" onclick="editBlogPost('<%= post.id %>')" style="padding: 0.375rem;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="btn btn-ghost" onclick="deleteBlogPost('<%= post.id %>')" style="padding: 0.375rem; color: #ef4444;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Projects Section -->
    <div class="section-content" id="section-projects">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Projects</h1>
            <p>Manage your portfolio projects</p>
          </div>
          <div class="page-actions">
            <button class="btn btn-primary" onclick="openProjectModal()" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Project
            </button>
            <a href="/projects" class="btn btn-secondary" style="padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 8px; font-size: 0.875rem;">View Projects</a>
          </div>
        </div>
        <div class="data-table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Project</th>
                <th>Status</th>
                <th>Year</th>
                <th>Stars</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="projectsTableBody">
              <% projects.forEach(project => { %>
                <tr>
                  <td>
                    <div class="table-title"><%= project.title %></div>
                    <div class="table-subtitle"><%= project.description.substring(0, 60) %>...</div>
                  </td>
                  <td>
                    <span class="badge badge-<%= project.status === 'shipped' ? 'shipped' : project.status === 'in-progress' ? 'progress' : 'archived' %>">
                      <span class="badge-dot"></span>
                      <%= project.status %>
                    </span>
                  </td>
                  <td><%= project.year %></td>
                  <td><%= project.stars %></td>
                  <td>
                    <div class="table-actions">
                      <button class="btn btn-ghost" onclick="editProject('<%= project.id %>')" style="padding: 0.375rem; color: orange;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="btn btn-ghost" onclick="deleteProject('<%= project.id %>')" style="padding: 0.375rem; color: #ef4444;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Lab Notes Section -->
    <div class="section-content" id="section-notes">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Lab Notes</h1>
            <p>Manage your lab notes and experiments</p>
          </div>
          <div class="page-actions">
            <button class="btn btn-primary" onclick="openLabNoteModal()" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Note
            </button>
          </div>
        </div>
        <div class="data-table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Icon</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="labNotesTableBody">
              <% labNotes.forEach(note => { %>
                <tr>
                  <td>
                    <div class="table-title"><%= note.title %></div>
                    <div class="table-subtitle"><%= note.description.substring(0, 60) %>...</div>
                  </td>
                  <td><span class="tag"><%= note.icon %></span></td>
                  <td><%= new Date(note.created_at).toLocaleDateString() %></td>
                  <td>
                    <div class="table-actions">
                      <button class="btn btn-ghost" onclick="editLabNote('<%= note.id %>')" style="padding: 0.375rem;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="btn btn-ghost" onclick="deleteLabNote('<%= note.id %>')" style="padding: 0.375rem; color: #ef4444;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Workbench Section -->
    <div class="section-content" id="section-workbench">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Workbench</h1>
            <p>Manage your active work items</p>
          </div>
          <div class="page-actions">
            <button class="btn btn-primary" onclick="openWorkbenchModal()" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Item
            </button>
          </div>
        </div>
        <div class="data-table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Progress</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="workbenchTableBody">
              <% workbenchItems.forEach(item => { %>
                <tr>
                  <td>
                    <div class="table-title"><%= item.title %></div>
                    <div class="table-subtitle"><%= item.description.substring(0, 60) %>...</div>
                  </td>
                  <td>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <div style="flex: 1; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden;">
                        <div style="width: <%= item.progress %>%; height: 100%; background: var(--primary); border-radius: 2px;"></div>
                      </div>
                      <span style="font-size: 0.75rem; color: var(--muted-foreground);"><%= item.progress %>%</span>
                    </div>
                  </td>
                  <td>
                    <span class="badge badge-<%= item.status === 'active' ? 'shipped' : item.status === 'paused' ? 'progress' : 'archived' %>">
                      <span class="badge-dot"></span>
                      <%= item.status %>
                    </span>
                  </td>
                  <td><span class="tag"><%= item.priority %></span></td>
                  <td>
                    <div class="table-actions">
                      <button class="btn btn-ghost" onclick="editWorkbenchItem('<%= item.id %>')" style="padding: 0.375rem;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="btn btn-ghost" onclick="deleteWorkbenchItem('<%= item.id %>')" style="padding: 0.375rem; color: #ef4444;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Settings Section -->
    <div class="section-content" id="section-settings">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Settings</h1>
            <p>Configure your site preferences</p>
          </div>
        </div>
        <div class="settings-card" style="background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; max-width: 800px;">
          <form id="settingsForm">
            <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem;">Site Information</h3>
            
            <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
              <div class="form-group">
                <label class="form-label">Site Title</label>
                <input type="text" class="form-input" id="settingSiteTitle" value="<%= settings.site_title %>" placeholder="Your site title">
              </div>
              <div class="form-group">
                <label class="form-label">Site Description</label>
                <input type="text" class="form-input" id="settingSiteDescription" value="<%= settings.site_description %>" placeholder="Brief description">
              </div>
            </div>

            <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem;">Author Information</h3>
            
            <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
              <div class="form-group">
                <label class="form-label">Author Name</label>
                <input type="text" class="form-input" id="settingAuthorName" value="<%= settings.author_name %>" placeholder="Your name">
              </div>
              <div class="form-group">
                <label class="form-label">Author Role</label>
                <input type="text" class="form-input" id="settingAuthorRole" value="<%= settings.author_role %>" placeholder="Your role">
              </div>
            </div>

            <h3 style="margin-bottom: 1.5rem; font-size: 1.125rem;">Social Links</h3>
            
            <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
              <div class="form-group">
                <label class="form-label">GitHub URL</label>
                <input type="url" class="form-input" id="settingGithub" value="<%= settings.github_url %>" placeholder="https://github.com/username">
              </div>
              <div class="form-group">
                <label class="form-label">Twitter URL</label>
                <input type="url" class="form-input" id="settingTwitter" value="<%= settings.twitter_url %>" placeholder="https://twitter.com/username">
              </div>
              <div class="form-group">
                <label class="form-label">LinkedIn URL</label>
                <input type="url" class="form-input" id="settingLinkedin" value="<%= settings.linkedin_url %>" placeholder="https://linkedin.com/in/username">
              </div>
              <div class="form-group">
                <label class="form-label">Contact Email</label>
                <input type="email" class="form-input" id="settingEmail" value="<%= settings.contact_email %>" placeholder="your@email.com">
              </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
              <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem;">Save Settings</button>
              <button type="button" class="btn btn-secondary" onclick="loadSettings()" style="padding: 0.75rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; font-size: 0.875rem;">Reset</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Import/Export Section -->
    <div class="section-content" id="section-export">
      <div class="content-area">
        <div class="page-header">
          <div class="page-header-info">
            <h1>Import / Export</h1>
            <p>Backup and restore your data</p>
          </div>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
          <!-- Export Card -->
          <div class="settings-card" style="background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
              <div style="width: 48px; height: 48px; background: rgba(34, 197, 94, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </div>
              <div>
                <h3 style="font-size: 1.125rem; margin-bottom: 0.25rem;">Export Data</h3>
                <p style="font-size: 0.875rem; color: var(--muted-foreground);">Download all your data as JSON</p>
              </div>
            </div>
            <p style="font-size: 0.875rem; color: var(--muted-foreground); margin-bottom: 1rem;">Export all projects, blog posts, lab notes, workbench items, and settings to a JSON file for backup.</p>
            <button id="exportDataBtn" class="btn btn-primary" style="width: 100%; padding: 0.75rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export All Data
            </button>
          </div>

          <!-- Import Card -->
          <div class="settings-card" style="background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
              <div style="width: 48px; height: 48px; background: rgba(59, 130, 246, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <div>
                <h3 style="font-size: 1.125rem; margin-bottom: 0.25rem;">Import Data</h3>
                <p style="font-size: 0.875rem; color: var(--muted-foreground);">Restore from backup</p>
              </div>
            </div>
            <p style="font-size: 0.875rem; color: var(--muted-foreground); margin-bottom: 1rem;">Import data from a previously exported JSON file. This will add new items to your existing data.</p>
            <input type="file" id="importFile" accept=".json" style="display: none;">
            <button id="importDataBtn" class="btn btn-secondary" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 8px; font-size: 0.875rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Import from File
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Project Modal -->
<div class="modal-overlay" id="projectModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title" id="projectModalTitle">Add New Project</h3>
      <button class="modal-close" onclick="closeModal('projectModal')">&times;</button>
    </div>
    <form id="projectForm">
      <div class="modal-body">
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Title *</label>
            <input type="text" class="form-input" id="projectTitle" required placeholder="Project name">
          </div>
          <div class="form-group">
            <label class="form-label">Slug *</label>
            <input type="text" class="form-input" id="projectSlug" required placeholder="project-slug">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Short Description *</label>
          <input type="text" class="form-input" id="projectDescription" required placeholder="Brief description">
        </div>
        <div class="form-group">
          <label class="form-label">Long Description</label>
          <textarea class="form-textarea" id="projectLongDescription" rows="4" placeholder="Detailed description (supports Markdown)"></textarea>
        </div>
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-select" id="projectStatus">
              <option value="in-progress">In Progress</option>
              <option value="completed">Completed</option>
              <option value="cancelled">Cancelled</option>
              <option value="shipped">Shipped</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Year</label>
            <input type="number" class="form-input" id="projectYear" value="<%= new Date().getFullYear() %>">
          </div>
          <div class="form-group">
            <label class="form-label">Stars</label>
            <input type="number" class="form-input" id="projectStars" value="0">
          </div>
          <div class="form-group">
            <label class="form-label">Forks</label>
            <input type="number" class="form-input" id="projectForks" value="0">
          </div>
        </div>
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">GitHub URL</label>
            <input type="url" class="form-input" id="projectGithub" placeholder="https://github.com/...">
          </div>
          <div class="form-group">
            <label class="form-label">Live URL</label>
            <input type="url" class="form-input" id="projectLive" placeholder="https://...">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tags (comma separated)</label>
          <input type="text" class="form-input" id="projectTags" placeholder="react, nodejs, typescript">
        </div>
        <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" id="projectFeatured">
            <span>Featured</span>
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" id="projectHighlight">
            <span>Highlight</span>
          </label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('projectModal')" style="padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 8px;">Cancel</button>
        <button type="submit" class="btn btn-primary" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px;">Save Project</button>
      </div>
    </form>
  </div>
</div>

<!-- Blog Post Modal -->
<div class="modal-overlay" id="blogPostModal">
  <div class="modal" style="max-width: 700px;">
    <div class="modal-header">
      <h3 class="modal-title" id="blogPostModalTitle">Add New Blog Post</h3>
      <button class="modal-close" onclick="closeModal('blogPostModal')">&times;</button>
    </div>
    <form id="blogPostForm">
      <div class="modal-body">
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Title *</label>
            <input type="text" class="form-input" id="blogTitle" required placeholder="Post title">
          </div>
          <div class="form-group">
            <label class="form-label">Slug *</label>
            <input type="text" class="form-input" id="blogSlug" required placeholder="post-slug">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Excerpt *</label>
          <input type="text" class="form-input" id="blogExcerpt" required placeholder="Brief summary">
        </div>
        <div class="form-group">
          <label class="form-label">Content (Markdown)</label>
          <textarea class="form-textarea" id="blogContent" rows="8" placeholder="Write your post content here..."></textarea>
        </div>
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Category</label>
            <select class="form-select" id="blogCategory">
              <option value="">Select Category</option>
              <option value="1">Engineering</option>
              <option value="2">Tutorial</option>
              <option value="3">Thoughts</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Tags (comma separated)</label>
            <input type="text" class="form-input" id="blogTags" placeholder="javascript, webdev">
          </div>
        </div>
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Author Name</label>
            <input type="text" class="form-input" id="blogAuthor" value="Theophilus" placeholder="Author name">
          </div>
          <div class="form-group">
            <label class="form-label">Author Role</label>
            <input type="text" class="form-input" id="blogAuthorRole" value="Software Engineer" placeholder="Author role">
          </div>
          <div class="form-group">
            <label class="form-label">Read Time</label>
            <input type="text" class="form-input" id="blogReadTime" value="5 min read" placeholder="e.g. 5 min read">
          </div>
        </div>
        <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" id="blogPublished">
            <span>Published</span>
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" id="blogFeatured">
            <span>Featured</span>
          </label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('blogPostModal')" style="padding: 0.625rem 1.25rem; border: 1px solid var(--border); border-radius: 8px;">Cancel</button>
        <button type="submit" class="btn btn-primary" style="padding: 0.625rem 1.25rem; background: var(--primary); color: var(--primary-foreground); border-radius: 8px;">Save Post</button>
      </div>
    </form>
  </div>
</div>

<!-- Lab Note Modal -->
<div class="modal-overlay" id="labNoteModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title" id="labNoteModalTitle">Add New Lab Note</h3>
      <button class="modal-close" onclick="closeModal('labNoteModal')">&times;</button>
    </div>
    <form id="labNoteForm">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Title *</label>
          <input type="text" class="form-input" id="labNoteTitle" required placeholder="Note title">
        </div>
        <div class="form-group">
          <label class="form-label">Description *</label>
          <input type="text" class="form-input" id="labNoteDescription" required placeholder="Brief description">
        </div>
        <div class="form-group">
          <label class="form-label">Content</label>
          <textarea class="form-textarea" id="labNoteContent" rows="6" placeholder="Note content..."></textarea>
        </div>
        <div class="form-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div class="form-group">
            <label class="form-label">Icon</label>
            <select class="form-select" id="labNoteIcon">
              <option value="code">Code</option>
              <option value="book">Book</option>
              <option value="cpu">CPU</option>
              <option value="database">Database</option>
              <option value="cloud">Cloud</option>
              <option value="terminal">Terminal</option>
              <option value="box">Box</option>
              <option value="zap">Zap</option>
