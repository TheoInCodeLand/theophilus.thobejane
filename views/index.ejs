<!-- Hero Section -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-label animate-fade-in-up">TheoInCode — Where Code Meets Curiosity</p>
        <h1 class="hero-title">
          Theo Thobejane:<br>
          <span class="gradient-text typing-cursor" id="typingText">AI/Software developer. <br> </span>
        </h1>
        <p class="hero-description animate-fade-in-up stagger-2">
          Full-stack developer & AI engineer with a passion for building tools, experiments, and open-source projects.
          <span class="highlight">4 production apps</span> — from enterprise RAG chatbots to real-time geospatial platforms. I don't just write code; I build systems that solve real problems.
        </p>
        <div class="hero-buttons animate-fade-in-up stagger-3">
          <a href="/projects" class="btn-primary">
            <span class="btn-text">Explore Projects</span>
            <span class="btn-arrow">&rarr;</span>
            <span class="btn-bg"></span>
          </a>
          <a href="/blog" class="btn-secondary">
            <span>Read the Blog</span>
            <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <div class="hero-visual animate-fade-in-up stagger-2">
        <div class="terminal-card" id="heroTerminal">
          <div class="terminal-dots">
            <span class="terminal-dot red" title="Close"></span>
            <span class="terminal-dot yellow" title="Minimize"></span>
            <span class="terminal-dot green" title="Maximize"></span>
          </div>
          <div class="terminal-title">
            <img src="/images/folder.png" alt="" width="12px"> 
            theophilus@lab — zsh — 80×24
          </div>
          <div class="terminal-content" id="terminalContent">
            <div class="terminal-output" id="terminalOutput"></div>
            <div class="terminal-input-line">
              <span class="terminal-prompt">
                <span class="prompt-user">theophilus</span><span class="prompt-at">@</span><span class="prompt-host">TheoInCodeLand</span> <span class="prompt-path">~</span> <span class="prompt-symbol">%</span>
              </span>
              <input type="text" class="terminal-input" id="terminalInput" autocomplete="off" spellcheck="false" placeholder="type 'help'..." />
              <span class="terminal-cursor">▋</span>
            </div>
          </div>
          <div class="floating-badge version">
            <div class="status-indicator">
              <span class="pulse-dot"></span>
              <span>v2.0.0</span>
            </div>
          </div>
          <div class="floating-badge date">
            <span>Last updated: <%= new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          </div>
        </div>
        <!-- <div class="hero-glow"></div> -->
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <span>Scroll to explore</span>
    <div class="line"></div>
  </div>
</section>

<!-- About Section -->
<section class="about" id="about">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label animate-fade-in-up">The Journey</p>
        <h2 class="section-title animate-fade-in-up stagger-1">From Java to AI</h2>
        <p class="section-description animate-fade-in-up stagger-2">
          Not your typical path. Started with academic Java, pivoted to full-stack JavaScript, 
          then dove deep into AI/ML. Built 4 production apps in 14 months while teaching others.
        </p>
      </div>
    </div>

    <div class="about-grid">
      <div class="about-card animate-fade-in-up stagger-2">
        <div class="about-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>The Academic Foundation</h3>
        <p>Advanced Diploma in ICT from University of Mpumalanga. Taught Python and Java to 50+ students, 
        improving test scores by 21%. Learned that teaching forces you to truly understand what you thought you knew.</p>
      </div>

      <div class="about-card animate-fade-in-up stagger-3">
        <div class="about-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3>The Self-Taught Pivot</h3>
        <p>While peers stopped at tutorials, I shipped production apps. Self-taught Node.js, PostgreSQL, 
        React Native, then AI/ML. Built Axiora AI—a RAG chatbot platform processing 500+ page websites in under 3 minutes.</p>
      </div>

      <div class="about-card animate-fade-in-up stagger-4">
        <div class="about-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3>The Full-Stack Reality</h3>
        <p>From geospatial delivery platforms with PostGIS to AI booking ecosystems with LLMs. 
        IBM-certified in Agile/Scrum. Obsessive cross-disciplinary learner who translates complex business needs into maintainable code.</p>
      </div>
    </div>

    <div class="about-terminal animate-fade-in-up stagger-5">
      <div class="terminal-dots">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
      </div>
      <div class="terminal-title">philosophy.md</div>
      <div class="about-terminal-content">
        <p><span class="terminal-comment">// My approach to software engineering</span></p>
        <p><span class="terminal-keyword">const</span> <span class="terminal-variable">philosophy</span> = {</p>
        <p class="terminal-indent">buildForScale: <span class="terminal-boolean">true</span>,</p>
        <p class="terminal-indent">automateEverything: <span class="terminal-boolean">true</span>,</p>
        <p class="terminal-indent">teachWhileLearning: <span class="terminal-boolean">true</span>,</p>
        <p class="terminal-indent">measureImpact: <span class="terminal-string">"94% relevance accuracy | 60% time saved | 4 production apps"</span>,</p>
        <p class="terminal-indent">currentStack: [<span class="terminal-string">"Python"</span>, <span class="terminal-string">"Node.js"</span>, <span class="terminal-string">"PostgreSQL"</span>, <span class="terminal-string">"AI/LLM"</span>]</p>
        <p>};</p>
      </div>
    </div>
  </div>
</section>

<!-- Projects Section -->
<section class="projects" id="projects">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label animate-fade-in-up">Artifacts</p>
        <h2 class="section-title animate-fade-in-up stagger-1">Technical Projects</h2>
        <p class="section-description animate-fade-in-up stagger-2">
          A collection of tools, experiments, and contributions to the open source community.
        </p>
      </div>
      <div class="filters animate-fade-in-up stagger-3">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="featured">Featured</button>
        <button class="filter-btn" data-filter="shipped">Shipped</button>
        <button class="filter-btn" data-filter="archived">Archived</button>
      </div>
    </div>

    <div class="projects-grid">
      <% featuredProjects.forEach((project, index) => { %>
        <article class="project-card <%= project.highlight ? 'highlight' : '' %> <%= project.featured ? 'featured' : '' %> animate-fade-in-up" style="animation-delay: <%= (index + 1) * 0.1 %>s">
          <% if (project.featured) { %>
            <div class="featured-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              <span>Featured</span>
            </div>
          <% } %>

          <div class="project-status">
            <span class="status-dot <%= project.status === 'shipped' ? 'shipped' : project.status === 'in-progress' ? 'in-progress' : 'archived' %>"></span>
            <span><%= project.status === 'in-progress' ? 'In Progress' : project.status.charAt(0).toUpperCase() + project.status.slice(1) %></span>
          </div>

          <p class="project-year"><%= project.year %></p>
          <h3 class="project-title"><%= project.title %></h3>
          <p class="project-description"><%= project.description %></p>

          <div class="project-stats">
            <span class="stat stars">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              <%= project.stars %>
            </span>
            <span class="stat forks">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="18" r="3"/>
                <circle cx="6" cy="6" r="3"/>
                <circle cx="18" cy="6" r="3"/>
                <path d="M6 9v3a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V9"/>
                <path d="M12 15V9"/>
              </svg>
              <%= project.forks %>
            </span>
          </div>

          <div class="project-tags">
            <% project.tags.slice(0, 4).forEach(tag => { %>
              <span class="project-tag"><%= tag %></span>
            <% }) %>
          </div>

          <div class="project-links">
            <% if (project.github_url) { %>
              <a href="<%= project.github_url %>" target="_blank" rel="noopener noreferrer" class="project-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
                <span>Source</span>
              </a>
            <% } %>
            <% if (project.live_url) { %>
              <a href="<%= project.live_url %>" target="_blank" rel="noopener noreferrer" class="project-link live">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                <span>Live Demo</span>
              </a>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="section-cta animate-fade-in-up">
      <a href="/projects" class="btn-secondary">
        <span>View All Projects</span>
        <span class="btn-arrow">&rarr;</span>
      </a>
    </div>
  </div>
</section>

