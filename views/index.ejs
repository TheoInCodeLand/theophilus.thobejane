<section class="workbench" id="workbench">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label animate-fade-in-up">Current Focus</p>
        <h2 class="section-title animate-fade-in-up stagger-1">Workbench</h2>
        <p class="section-description animate-fade-in-up stagger-2">What's currently on the workbench — active projects, experiments in progress, and things being built.</p>
      </div>
    </div>

    <div class="workbench-terminal animate-fade-in-up stagger-2">
      <div class="terminal-dots">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
      </div>
      <div class="terminal-title">workbench.status</div>
      <div class="workbench-content">
        <% workbenchItems.forEach((item) => { %>
          <div class="workbench-item">
            <div class="workbench-item-header">
              <span class="workbench-item-name"><%= item.title %></span>
              <span class="workbench-item-progress"><%= item.progress %>%</span>
            </div>
            <div class="workbench-progress-bar">
              <div class="workbench-progress-fill" style="width: <%= item.progress %>"></div>
            </div>
            <p class="workbench-item-desc"><%= item.description %></p>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
  <script src="/js/hero-terminal.js"></script>
</section>

