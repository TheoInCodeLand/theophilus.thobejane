<!-- Lab Notes Section -->
<section class="lab-notes" id="notes">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label animate-fade-in-up">Field Notes</p>
        <h2 class="section-title animate-fade-in-up stagger-1">Development Notes</h2>
