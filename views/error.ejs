<div class="error-container" style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
  <div class="error-content" style="text-align: center; max-width: 400px;">
    <h1 class="error-title" style="font-size: 4rem; font-weight: 700; margin-bottom: 1rem; background: linear-gradient(135deg, var(--primary), oklch(from var(--primary) l c h / 0.7)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Oops!</h1>
    <p class="error-message" style="font-size: 1.125rem; color: var(--muted-foreground); margin-bottom: 2rem;"><%= error || 'Something went wrong' %></p>
    <a href="/" class="btn-primary" style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.75rem; border-radius: 8px; border: 1px solid var(--primary); background: oklch(from var(--primary) l c h / 0.1); color: var(--primary); font-family: var(--font-mono); font-size: 0.875rem; text-decoration: none; transition: all 0.3s ease;">
      <span>Go Home</span>
      <span>&rarr;</span>
    </a>
  </div>
</div>
