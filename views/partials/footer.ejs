<footer class="footer" id="connect">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-left">
        <p class="label">Connect</p>
        <h2>Let's build something <span>together</span></h2>
        <p>Always interested in collaborations, interesting problems, and conversations about code, design, and everything in between.</p>
        <a href="mailto:<%= settings?.contact_email || 'hello@Theophilus.dev' %>" class="cta-button">
          <span class="text">send a signal</span>
          <span class="arrow">&rarr;</span>
        </a>
      </div>

      <div class="footer-right">
        <p class="label">Find me elsewhere</p>
        <div class="footer-links">
          <a href="<%= settings?.github_url || 'https://github.com' %>" target="_blank" rel="noopener noreferrer" class="footer-link">
            <div class="footer-link-left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
              <span class="footer-link-name">GitHub</span>
              <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <span class="footer-link-handle">@Theophilus</span>
          </a>
          <a href="<%= settings?.twitter_url || 'https://twitter.com' %>" target="_blank" rel="noopener noreferrer" class="footer-link">
            <div class="footer-link-left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
              </svg>
              <span class="footer-link-name">Twitter</span>
              <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <span class="footer-link-handle">@Theophilus</span>
          </a>
          <a href="<%= settings?.linkedin_url || 'https://linkedin.com' %>" target="_blank" rel="noopener noreferrer" class="footer-link">
            <div class="footer-link-left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              <span class="footer-link-name">LinkedIn</span>
              <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <span class="footer-link-handle">/in/Theophilus</span>
          </a>
          <a href="mailto:<%= settings?.contact_email || 'hello@Theophilus.dev' %>" class="footer-link">
            <div class="footer-link-left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span class="footer-link-name">Email</span>
            </div>
            <span class="footer-link-handle"><%= settings?.contact_email || 'hello@Theophilus.dev' %></span>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-status">
        <div class="status-dot">
          <span class="ping"></span>
          <span class="dot"></span>
        </div>
        <span>Forged with</span>
        <svg class="heart" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span>& code</span>
      </div>

      <div class="footer-social">
        <a href="<%= settings?.github_url || 'https://github.com' %>" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
        <a href="<%= settings?.twitter_url || 'https://twitter.com' %>" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
          </svg>
        </a>
        <a href="<%= settings?.linkedin_url || 'https://linkedin.com' %>" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>

      <p class="footer-copyright">
        &copy; <%= new Date().getFullYear() %> <%= settings?.site_title || 'Theophilus' %>. All rights reserved.
      </p>
    </div>
  </div>
</footer>
