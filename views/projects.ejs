<section class="projects-section">
  <div class="container">
    <!-- Hero -->
    <div class="projects-hero">
      <p class="label">Artifacts</p>
      <h1>Open Source Projects</h1>
      <p>A collection of tools, experiments, and contributions to the open source community. Built with passion, maintained with care.</p>
    </div>

    <!-- Search and Filters -->
    <div class="filters-section">
      <!-- Search -->
      <div class="search-wrapper">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        <input type="text" class="search-input" id="searchInput" placeholder="Search projects..." value="<%= filter?.search || '' %>">
      </div>

      <!-- Status Filters -->
      <div class="status-filters" id="statusFilters">
        <a href="/projects" class="filter-btn <%= !filter?.status ? 'active' : '' %>">all</a>
        <a href="/projects?status=shipped" class="filter-btn <%= filter?.status === 'shipped' ? 'active' : '' %>">shipped</a>
        <a href="/projects?status=in-progress" class="filter-btn <%= filter?.status === 'in-progress' ? 'active' : '' %>">in-progress</a>
        <a href="/projects?status=archived" class="filter-btn <%= filter?.status === 'archived' ? 'active' : '' %>">archived</a>
      </div>

      <!-- Tag Filters -->
      <div class="tag-filters" id="tagFilters">
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
        <% allTags.slice(0, 8).forEach(tag => { %>
          <button class="tag-btn" data-tag="<%= tag %>"><%= tag %></button>
        <% }) %>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="projects-grid" id="projectsGrid">
      <% projects.forEach((project, index) => { %>
        <article class="project-card <%= project.highlight ? 'highlight' : '' %> <%= project.featured ? 'featured' : '' %>" style="animation-delay: <%= index * 0.08 %>s">
          <% if (project.featured) { %>
            <div class="featured-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              <span>Featured</span>
            </div>
          <% } %>

          <div class="project-status">
            <span class="status-dot <%= project.status === 'shipped' ? 'shipped' : project.status === 'in-progress' ? 'in-progress' : 'archived' %>"></span>
            <span><%= project.status === 'in-progress' ? 'In Progress' : project.status.charAt(0).toUpperCase() + project.status.slice(1) %></span>
          </div>

          <p class="project-year"><%= project.year %></p>
          <h3 class="project-title"><%= project.title %></h3>
          <p class="project-description"><%= project.description %></p>

          <div class="project-stats">
            <span class="stat stars">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              <%= project.stars %>
            </span>
            <span class="stat forks">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="18" r="3"/>
                <circle cx="6" cy="6" r="3"/>
                <circle cx="18" cy="6" r="3"/>
                <path d="M6 9v3a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V9"/>
                <path d="M12 15V9"/>
              </svg>
              <%= project.forks %>
            </span>
          </div>

          <div class="project-tags">
            <% project.tags.slice(0, 4).forEach(tag => { %>
              <span class="project-tag"><%= tag %></span>
            <% }) %>
          </div>

          <div class="project-links">
            <% if (project.github_url) { %>
              <a href="<%= project.github_url %>" target="_blank" rel="noopener noreferrer" class="project-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
                <span>Source</span>
              </a>
            <% } %>
            <% if (project.live_url) { %>
              <a href="<%= project.live_url %>" target="_blank" rel="noopener noreferrer" class="project-link live">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                <span>Live Demo</span>
              </a>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <!-- Empty State -->
    <% if (projects.length === 0) { %>
      <div class="empty-state">
        <p>No projects found matching your criteria.</p>
      </div>
    <% } %>
  </div>
</section>
